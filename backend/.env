# Environment
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://archguard:archguard_secret@localhost:5432/archguard

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=archguard_neo4j

# Redis
REDIS_URL=redis://localhost:6379/0

# Document Extraction Provider
DOCUMENT_EXTRACTOR_PROVIDER=auto

# Local AI Pipeline (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5-coder:7b
OLLAMA_VISION_MODEL=qwen2.5-vl:latest

# Google Gemini (Fallback)
GEMINI_API_KEY=AIzaSyDHU9Zr4a3qQfsjLr3VaYNkFF4oW5WidA4


# OCR provider (auto uses Ollama, set to disabled to turn off)
DOCUMENT_OCR_PROVIDER=auto
DOCUMENT_OCR_TEXT_PREVIEW_LIMIT=1000

# JWT
JWT_SECRET_KEY=super-secret-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=ArchGuard
