# Environment
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://archguard:archguard_secret@localhost:5432/archguard

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=archguard_neo4j

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=super-secret-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=ArchGuard
